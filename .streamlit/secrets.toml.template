# ── Ledger secrets template ────────────────────────────────────────────────
#
# Copy this file to .streamlit/secrets.toml and fill in values if deploying
# to Streamlit Community Cloud, Railway, or Render.
#
# For local use: you do NOT need a secrets.toml at all.
# Ledger reads from local SQLite only — no API keys required.
#
# NEVER commit .streamlit/secrets.toml to Git.
# This template file (secrets.toml.template) is safe to commit.
# ──────────────────────────────────────────────────────────────────────────

# Optional: set a password to protect the deployed app.
# If set, users must enter this password to view the app.
# (Implement check in app.py — see README for instructions)
# app_password = "change-me"

# Optional: path to a read-only demo database on the deployment server.
# Leave blank to use the default data/finance.db path.
# demo_db_path = ""
